# .env.example — all supported environment variables with defaults

# === Dashboard (SvelteKit) ===
# If set, dashboard connects to Postgres instead of SQLite
DATABASE_URL=
# Local SQLite path for the dashboard (relative to dashboard/ cwd)
SQLITE_PATH=../etl/data/dynasty.db

# === Sleeper ===
SLEEPER_USERNAME=your_sleeper_handle
SLEEPER_USER_ID=
SLEEPER_SEASON=2026
SLEEPER_BASE_URL=https://api.sleeper.app/v1

# === FantasyCalc ===
FANTASYCALC_BASE_URL=https://api.fantasycalc.com

# === DynastyProcess ===
DP_BASE_URL=https://raw.githubusercontent.com/dynastyprocess/data/master/files
DP_REPO_URL=https://github.com/dynastyprocess/data.git
DP_CROSSWALK_URL=https://raw.githubusercontent.com/dynastyprocess/data/master/files/db_playerids.csv

# === nflverse ===
NFLVERSE_STATS_URL=https://github.com/nflverse/nflverse-data/releases/download/stats_player/stats_player_week_{season}.csv

# === Paths ===
DATA_DIR=etl/data
DB_PATH=etl/data/dynasty.db
CSV_OUTPUT_DIR=etl/data/csv

# === Docker / Scheduling ===
# Cron expression for ETL runs (default: daily at 6am UTC)
# Format: seconds minutes hours day-of-month month day-of-week
ETL_SCHEDULE=0 0 6 * * *

# === Misc ===
ETL_USER_AGENT=dynasty-portfolio-etl/2.0 (+analytics-portfolio-project)
PLAYER_CACHE_TTL_HOURS=24
LEAGUE_ID_FILTER=
BACKFILL_PREVIOUS_SEASONS=true
DP_ARCHIVE_SINCE=2019-01-01
OUTCOMES_FIRST_SEASON=2019
OUTCOMES_LAST_SEASON=2025
